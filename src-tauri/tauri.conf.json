{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "zero-desktop",
  "version": "0.1.0-alpha.2",
  "identifier": "com.gitlawb.zero-desktop",
  "build": {
    "frontendDist": "../dist/spa",
    "devUrl": "http://localhost:9000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "zero-desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/zero"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBMzVBNjFCMzdDNUM2MzUKUldRMXhzVTNHNlkxK3NXSUtjOVMrNWVuOHN5QVRxMXErZ3pZKzlHWEtQRHJKR3k1Tm5GYnd4UCsK",
      "endpoints": ["https://github.com/pdl-clay/zero-desktop/releases/latest/download/latest.json"]
    }
  }
}
